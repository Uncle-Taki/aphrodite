# Aphrodite environment template.
# Copy this file to .env for local development and replace secrets before sharing
# or deploying. Keep APP_PORT=8080 with the current Docker Compose port mapping.

APP_ENV=development
APP_DEBUG=true
APP_PORT=8080

JWT_SECRET=replace-with-at-least-32-byte-jwt-secret
JWT_ACCESS_TOKEN_TTL=24h
JWT_MIN_SECRET_BYTES=32
AUTH_BCRYPT_COST=10
SUPER_ADMIN_KEY=replace-with-super-admin-bootstrap-key

POST_TITLE_MAX_LENGTH=200
POST_CONTENT_MAX_LENGTH=100000
COMMENT_CONTENT_MAX_LENGTH=10000

USER_DEFAULT_LIMIT=20
USER_MAX_LIMIT=100
POST_DEFAULT_LIMIT=20
POST_MAX_LIMIT=100
COMMENT_DEFAULT_LIMIT=50
COMMENT_MAX_LIMIT=200

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=aphrodite
POSTGRES_PASSWORD=change-me
POSTGRES_DB=aphrodite
POSTGRES_SSLMODE=disable
POSTGRES_MAINTAIN_ASSIGNMENT_INDEXES=false

REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

CRYPTO_MASTER_KEY=replace-with-32-byte-master-key!

USAGE_RECONCILE_INTERVAL=0s
